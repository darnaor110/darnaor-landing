{
  "version": 2,
  "buildCommand": "",
  "functions": {
    "api/generate.js":    { "runtime": "nodejs20.x" },
    "api/send-email.js":  { "runtime": "nodejs20.x" }
  },
  "rewrites": [
    { "source": "/api/generate",   "destination": "/api/generate.js" },
    { "source": "/api/send-email", "destination": "/api/send-email.js" },
    { "source": "/quiz",           "destination": "/fitness-quiz/index.html" },
    { "source": "/quiz/(.*)",      "destination": "/fitness-quiz/$1" },
    { "source": "/(.*)",           "destination": "/darnaorlanding/$1" }
  ]
}
